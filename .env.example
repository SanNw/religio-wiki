# Copie este arquivo para ".env" e defina senhas fortes antes de subir os containers
DB_PASSWORD=troque-esta-senha
DB_ROOT_PASSWORD=troque-esta-senha-root

# Token da API da Hostinger (usado pelo MCP configurado em .mcp.json)
# Gere em: hPanel > Perfil > Informacoes da conta > API > Gerar token
HOSTINGER_API_TOKEN=coloque-seu-token-aqui
