# Copie este arquivo para ".env" e defina senhas fortes antes de subir os containers
DB_PASSWORD=troque-esta-senha
DB_ROOT_PASSWORD=troque-esta-senha-root

# ---------- E-mail (SMTP) — confirmação de conta ----------
# Sem isso preenchido, o wiki NÃO envia o e-mail de confirmação de conta:
# LocalSettings-snippet.php só liga $wgSMTP quando RW_SMTP_HOST não está
# vazio (ver docker-compose.yml, que repassa estas variáveis ao container).
# Deixe tudo comentado/vazio se ainda não for usar essa funcionalidade — o
# resto do wiki funciona normalmente, só a confirmação por e-mail fica
# desligada. Use as credenciais de um provedor SMTP de verdade (ex.: um
# domínio de e-mail transacional, Gmail com "senha de app", Amazon SES,
# Mailgun, SendGrid etc.) — NUNCA um e-mail pessoal comum.
# RW_SMTP_HOST=smtp.seu-provedor.com
# RW_SMTP_PORT=587
# RW_SMTP_USER=usuario@religiowiki.com
# RW_SMTP_PASS=troque-esta-senha-smtp
# RW_SMTP_IDHOST=religiowiki.com
# RW_MAIL_FROM=no-reply@religiowiki.com
